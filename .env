# Development
CI_ENVIRONMENT = development
app.baseURL = 'http://example.com/' #Always use the full path to index.php and use a trailing slash on your base URL! Also think about the protocol, the debug toolbar is very picky about this. use current_url(); to check what url the app sees.

# production
# CI_ENVIRONMENT = production
# app.baseURL = 'http://example.com/' #Always use the full path to index.php and use a trailing slash on your base URL! Also think about the protocol, the debug toolbar is very picky about this. use current_url(); to check what url the app sees.

database.default.DBDriver = SQLite3
database.default.database = database.db